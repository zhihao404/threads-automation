{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": [
    "./**/*.ts",
    "../src/lib/queue/types.ts",
    "../src/db/schema.ts",
    "../src/db/index.ts",
    "../src/lib/threads/client.ts",
    "../src/lib/threads/types.ts",
    "../src/lib/cron/parser.ts",
    "../src/lib/templates/render.ts"
  ],
  "exclude": ["node_modules"]
}
